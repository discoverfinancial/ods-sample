{
  "compilerOptions": {
    "outDir": "build/",
    "resolveJsonModule": true,
    "target": "es2021",
    "module": "commonjs",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "jsx": "react",
  },
  "include": ["src/*.ts", "src/controllers/*.ts", "src/etl/**/*.ts", "src/ui/src/common/**/*.ts"]
}
