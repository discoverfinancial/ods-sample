{
	"name": "ods-app",
	"version": "1.0.0",
	"description": "Ods App",
	"scripts": {
		"clean": "rm -rf node_modules && rm -rf build && rm -rf src/ui/node_modules && rm -rf src/ui/build && rm package-lock.json; rm src/ui/package-lock.json",
		"clean-api": "rm -rf node_modules && rm -rf build && rm package-lock.json",
		"test": "jest --watchAll=false --coverage",
		"test-no-coverage": "jest",
		"build": "npm run build-api && npm run build-ui",
		"build-ui": "cd src/ui && npm run build",
		"build-api": "npm config set strict-ssl false && NODE_TLS_REJECT_UNAUTHORIZED=0 npm install --loglevel verbose && echo 'calling tsoa' && tsoa spec-and-routes && echo 'calling tsc' && tspc --listEmittedFiles && echo 'tsc done' && cp ./src/adminSandboxFunctions.js ./build/ods-framework",
		"debug": "nodemon --exec ts-node src/app.ts",
		"cluster": "nodemon --exec ts-node src/cluster.ts",
		"prepare": "ts-patch install",
		"debug-basic-auth": "BASIC_AUTH_ENABLED=true http_proxy= https_proxy= npm run debug",
		"debug-no-auth": "http_proxy= https_proxy= npm run debug",
		"debug-inspect": "http_proxy= https_proxy= nodemon --exec node --inspect=0.0.0.0:9229 -r ts-node/register src/app.ts",
		"start": "node build/app.js",
		"ts-start": "ts-node src/app.ts",
		"tsoa:spec": "tsoa spec",
		"tsoa:routes": "tsoa routes",
		"tsoa:build": "npm run tsoa:spec && npm run tsoa:routes",
		"lint": "npx eslint src",
		"lint:fix": "npx eslint . --fix",
		"check": "NODE_TLS_REJECT_UNAUTHORIZED=0 npm-check"
	},
	"author": "",
	"license": "MIT",
	"homepage": ".",
	"overrides": {
		"mongodb": "^4.5.0",
		"mongoose": "^6.3.2",
		"@types/express": "^4.17.13",
		"express": "^4.18.1",
		"jsonwebtoken": "9.0.2",
		"node": "22.19.0"
	},
	"dependencies": {
		"@types/adm-zip": "^0.5.7",
		"@types/express": "^4.17.13",
		"@types/node": "^24.10.1",
		"@types/nodemon": "^3.1.1",
		"@types/semver": "^7.5.8",
		"@types/swagger-ui-express": "^4.1.8",
		"@types/uuid": "^8.3.4",
		"adm-zip": "^0.5.16",
		"axios": "^1.13.2",
		"compression": "^1.8.1",
		"croner": "^8.1.1",
		"dlms-base": "file:dlms-base-2.0.2.tgz",
		"dlms-server": "file:dlms-server-2.0.2.tgz",
		"express": "^4.18.1",
		"fastest-levenshtein": "^1.0.16",
		"lodash": "^4.17.21",
		"mongodb": "^4.5.0",
		"nodemon": "^3.1.11",
		"ods-common": "file:ods-common-1.0.0.tgz",
		"ods-framework": "file:ods-framework-1.0.0.tgz",
		"swagger-ui-express": "^5.0.1",
		"ts-node": "^10.9.2",
		"tsoa": "^6.6.0",
		"typescript": "^5.9.3",
		"typia": "^12.1.1",
		"undici": "^7.16.0",
		"uuid": "^8.3.2",
		"v8-sandbox": "^3.2.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.38.0",
		"@jest/expect": "^30.0.5",
		"@testing-library/jest-dom": "^6.6.4",
		"@types/global-agent": "^2.1.3",
		"@types/jest": "^30.0.0",
		"@typescript-eslint/eslint-plugin": "^8.46.2",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"identity-obj-proxy": "^3.0.0",
		"jest-canvas-mock": "^2.5.2",
		"jest-environment-jsdom": "^30.0.5",
		"npm-check": "^6.0.1",
		"ts-jest": "^29.4.1",
		"ts-patch": "^3.3.0"
	}
}
